%% 双密钥体系图 - 纵向流程布局
flowchart TB
    subgraph 种子["密钥生成起点"]
        Seed["随机种子<br/>32字节高熵随机数"]
    end
    
    subgraph 密钥派生["密钥派生"]
        direction LR
        Ed25519["Ed25519密钥对<br/>签名密钥"]
        X25519["X25519密钥对<br/>加密密钥"]
    end
    
    Seed -.->|"Ed25519算法"| Ed25519
    Ed25519 -.->|"Ed25519私钥派生"| X25519
    
    subgraph 用途分离["密钥用途分离"]
        direction LR
        Auth["NATS JWT认证<br/>身份验证"] 
        Encrypt["NaCl Box加密<br/>消息端到端加密"]
    end
    
    Ed25519 --> Auth
    X25519 --> Encrypt
    
    subgraph 安全特性["安全特性"]
        direction TB
        S1["签名与加密密钥分离<br/>避免单点失效风险"]
        S2["Ed25519→X25519单向派生<br/>密码学不可逆"]
        S3["本地安全存储<br/>私钥永不离开设备"]
    end
    
    Auth --> S1
    Encrypt --> S1
    X25519 --> S2
    Seed --> S3
    
    style Seed fill:#e3f2fd,stroke:#1976d2
    style Ed25519 fill:#fff3e0,stroke:#f57c00
    style X25519 fill:#e8f5e9,stroke:#388e3c
    style Auth fill:#fff3e0,stroke:#f57c00
    style Encrypt fill:#e8f5e9,stroke:#388e3c
    style 安全特性 fill:#f3e5f5,stroke:#7b1fa2
