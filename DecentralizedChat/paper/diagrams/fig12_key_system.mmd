%% 双密钥体系图
graph TB
    subgraph 密钥生成["密钥生成流程"]
        Seed["随机种子<br/>32字节"] --> Ed25519["Ed25519密钥对<br/>签名密钥"]
        Seed --> |派生| X25519["X25519密钥对<br/>加密密钥"]
    end
    
    subgraph 密钥用途["密钥用途分离"]
        Ed25519 --> |用于| Auth["NATS JWT认证<br/>身份验证"]
        X25519 --> |用于| Encrypt["NaCl Box加密<br/>消息加密"]
    end
    
    subgraph 安全特性["安全特性"]
        S1["签名与加密分离<br/>避免单点失效"]
        S2["Ed25519→X25519单向派生<br/>不可逆向推导"]
        S3["本地存储<br/>不上传服务端"]
    end
    
    Encrypt --> S1
    Auth --> S1
    X25519 --> S2
    Seed --> S3
    
    style Seed fill:#e3f2fd,stroke:#1976d2
    style Ed25519 fill:#fff3e0,stroke:#f57c00
    style X25519 fill:#e8f5e9,stroke:#388e3c
    style Auth fill:#fff3e0,stroke:#f57c00
    style Encrypt fill:#e8f5e9,stroke:#388e3c
